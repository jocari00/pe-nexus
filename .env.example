# PE-Nexus Environment Configuration

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Choose your LLM provider: anthropic, groq, ollama, or none
# - groq: FREE tier available, uses Llama 3 (recommended for class demo)
# - ollama: Completely FREE, runs locally on your machine
# - anthropic: Paid, uses Claude (best quality)
# - none: Rule-based only, no AI features
LLM_PROVIDER=groq

# -----------------------------------------------------------------------------
# GROQ API (FREE - Recommended for demos)
# Get your free API key at: https://console.groq.com
# Free tier: 30 requests/minute, 14,400 requests/day
# -----------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# OLLAMA (FREE - Local, no API key needed)
# Install: https://ollama.ai
# Run: ollama pull llama3.2
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------------------------------------------
# ANTHROPIC (Paid - Best quality)
# Get API key at: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# =============================================================================
# DATABASE
# =============================================================================
# SQLite for development (default), PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./pe_nexus.db

# =============================================================================
# VECTOR STORE (ChromaDB)
# =============================================================================
CHROMA_PERSIST_DIR=./chroma_data

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# OPTIONAL: External APIs for IntelligenceScout
# =============================================================================
# FRED API for economic data (free): https://fred.stlouisfed.org/docs/api/
FRED_API_KEY=

# NewsAPI for news aggregation: https://newsapi.org
NEWSAPI_KEY=
